FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy everything
COPY . .

# Build and test all target frameworks
RUN dotnet build Opener/Opener.csproj -c Release

# Run unit tests on both frameworks
RUN dotnet test Opener.Tests/Opener.Tests.csproj -c Release --verbosity normal

# Pack for both frameworks (multi-targeting creates both in the package)
RUN dotnet pack Opener/Opener.csproj -c Release -o /nupkg

# Install the tool from the local package (uses net10.0 by default on Linux)
RUN dotnet tool install --global --add-source /nupkg com.chirravuris.opener

# Add tool to path
ENV PATH="/root/.dotnet/tools:${PATH}"

# Ensure we have bash and necessary utilities (git is required by the sync integration test)
RUN apt-get update && apt-get install -y bash curl git

# Run integration tests using bash script
COPY tests/integration_test.sh /test.sh
RUN chmod +x /test.sh

CMD ["/test.sh"]
